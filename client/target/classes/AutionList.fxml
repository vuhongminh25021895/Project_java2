<?import javafx.scene.text.Font?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="View.AuctionListController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox alignment="TOP_RIGHT" prefHeight="607.0" prefWidth="683.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <children>
            <TextField alignment="TOP_CENTER" editable="false" prefHeight="47.0" prefWidth="643.0" text="Đấu Giá Sản Phẩm">
                <font>
                    <Font size="28.0" />
                </font>
            </TextField>
            <HBox alignment="TOP_RIGHT" maxWidth="250.0" prefHeight="43.0" prefWidth="175.0">
                <padding>
                    <Insets right="20.0" top="10.0" />
                </padding>
                <children>
                    <MenuButton mnemonicParsing="false" text="Hello,account1">
                        <items>
                            <MenuItem mnemonicParsing="false" text="thông tin tài khoản" />
                            <MenuItem mnemonicParsing="false" text="đăng xuất" />
                        </items>
