            </HBox>
            <TableView fx:id="tableSanPhams" prefHeight="312.0" prefWidth="653.0">
                <columns>
                    <TableColumn fx:id="colTen" prefWidth="51.33331620693207" text="Số" />
                    <TableColumn fx:id="colTenSanPham" prefWidth="104.66669082641602" text="Tên Sản Phẩm" />
                    <TableColumn fx:id="colMoTa" prefWidth="141.3332977294922" text="Mô Tả" />
                    <TableColumn fx:id="colGiaKhoiDiem" prefWidth="103.33331298828125" text="Giá Khởi Điểm" />
                    <TableColumn fx:id="colGiaCaoNhat" minWidth="0.0" prefWidth="93.33331298828125" text="Giá Cao Nhất" />
                    <TableColumn fx:id="colBatDau" maxWidth="221.999989827474" prefWidth="80.66671752929688" text="bắt đầu" />
                    <TableColumn fx:id="colKetThuc" maxWidth="67.33333333333337" prefWidth="67.33333333333337" text="kết thúc" />
                </columns>
            </TableView>
            <HBox alignment="BOTTOM_CENTER" maxWidth="1.7976931348623157E308" prefHeight="53.0" prefWidth="643.0">
                <children>
                    <TextField maxWidth="1.7976931348623157E308" promptText="Nhập giá (giá phải cao hơn giá hiện tại)....">
                        <font>
